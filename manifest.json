{
  "manifest_version": 3,
  "name": "TideTrack",
  "version": "2.0",
  "description": "Study smarter, not longer. Track focus vs distraction in real time and get insights that actually help.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["login.html", "tide.html", "tide.js", "rooms.html", "rooms.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
